	column FinancialYear = ```
			
			VAR change_date = 'v_SDD_ChangeManagementReport_ChangeRequests'[StartDate]
			VAR change_year = YEAR(change_date)
			VAR change_month = MONTH(change_date)
			VAR financial_year_start = IF(change_month >= 7, change_year, change_year - 1) 
			RETURN 
			    financial_year_start & " - " & (financial_year_start + 1)
			```
		lineageTag: cf3d2c96-d7db-4095-9a7c-c0b1aaa622a7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

